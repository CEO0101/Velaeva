{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "velaeva.com" }],
      "destination": "https://www.velaeva.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-DNS-Prefetch-Control", "value": "on" }
      ]
    }
  ]
}
